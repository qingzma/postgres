        {
            "name": "(lldb) pg Launch",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/src/backend/postgres",
            "args": [
                "-D",
                "/usr/local/pgsql/data"
            ],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "lldb"
        },
        {
            "name": "(lldb) pg Launch help",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/src/backend/postgres",
            "args": [
                "--help",
                ""
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "lldb"
        },
        {
            "name": "(lldb) Launch",
            "type": "cppdbg",
            "request": "attach",
            "program": "${workspaceFolder}/src/backend/postgres",
            "MIMode": "lldb"
        }
    ]
}